{
  /**
   ** EXTENSIONS
   **/
  "extensions.autoUpdate": true,

  /**
   ** EXPLORER
   **/

  // Breadcrumb
  "breadcrumbs.enabled": true,

  // Disable compact folder display
  "explorer.compactFolders": false,

  // Remove warning when moving to trash
  "explorer.confirmDelete": false,

  // No confirmation when moving files
  "explorer.confirmDragAndDrop": false,

  // Auto open file in explorer when opened in editor
  "explorer.autoReveal": true,

  /**
   ** SIDEBAR
   **/

  // Beautiful outline view
  "outline.showVariables": false,
  "outline.showFields": false,
  "outline.showFunctions": true,
  "outline.collapseItems": "alwaysCollapse",

  /**
   ** FILES
   **/

  // Auto save
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 200,

  // End of line
  "files.eol": "\n",

  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "files.enableTrash": true,
  "files.autoGuessEncoding": true,
  "files.simpleDialog.enable": true,

  /**
   ** EDITOR
   **/

  // Editing closing tag on type
  "editor.linkedEditing": true,
  "editor.renameOnType": true,

  // Force link hover click
  "editor.links": true,

  // Format on save
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSaveMode": "modifications",
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Custom Font
  // "editor.fontFamily": "Menlo, Monaco, 'Courier New', monospace", // default
  "editor.fontFamily": "Fira Code, Menlo, Monaco, 'Courier New', monospace",
  // "editor.fontFamily": "'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": true,

  // Cursor
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,

  // Inlay hints (Ctrl+Alt to show)
  "editor.inlayHints.enabled": "offUnlessPressed",

  // Hover delay (less intrusive)
  "editor.hover.delay": 1500,

  // Autocomplete in strings (Tailwind, paths...)
  "editor.quickSuggestions": {
    "strings": true
  },

  // Prioritize nearby symbols in autocomplete
  "editor.suggest.localityBonus": true,

  // Scope search to multiline selection
  "editor.find.autoFindInSelection": "multiline",

  // Sticky scroll (pin function/class name)
  "editor.stickyScroll.enabled": true,

  // Padding
  "editor.padding.top": 10,

  // Format JSON
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "json.format.enable": true,

  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true
  },
  "[markdown]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "always"
    }
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "[php]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // EsLint
  "eslint.validate": ["javascript", "typescript"],
  "eslint.format.enable": true,

  // Enable auto formatting
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.fixAll.eslint": "always",
    "source.organizeImports": "always",
    "source.addMissingImports": "always"
  },

  // Menu tabs wrapped for better visibility
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 100,
  "editor.wrappingIndent": "same",

  // Bracket pair colorization (enabled by default since v1.67)
  "editor.guides.bracketPairs": "active",
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveBracketPair": true,

  // Disable minimap
  "editor.minimap.enabled": false,

  // Diff editor
  "diffEditor.hideUnchangedRegions.enabled": true,

  // Accessibility (disable for performance)
  "editor.accessibilitySupport": "off",

  /**
   ** GIT
   **/

  // Enable git
  "git.enabled": true,
  "git.autofetch": true,
  // No confirmation when syncing
  "git.confirmSync": false,
  // Rebase when syncing
  "git.rebaseWhenSync": true,
  // Discard untracked files to trash instead of deleting
  "git.discardUntrackedChangesToTrash": true,
  // Verbose commit with folding support
  "git.verboseCommit": true,
  // Blame ignores whitespace changes
  "git.blame.ignoreWhitespace": true,
  // Git display info (everywhere)
  "scm.diffDecorations": "all",
  "workbench.editor.decorations.badges": true,
  // Show as tree
  "scm.defaultViewMode": "tree",

  /**
   ** WORKBENCH
   **/

  // Wrap tabs for better visibility
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.wrapTabs": true,
  "workbench.editor.tabSizing": "fit",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 8,

  // Disable preview mode for tabs
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,

  // Pinned tabs on separate row
  "workbench.editor.pinnedTabsOnSeparateRow": true,

  // Smooth scrolling in lists
  "workbench.list.smoothScrolling": true,

  // Sticky scroll in explorer tree
  "workbench.tree.enableStickyScroll": true,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.tree.indent": 15,

  // No startup editor
  "workbench.startupEditor": "none",

  // Cursor Rules edition
  "workbench.editorAssociations": {
    "*.mdc": "default"
  },

  /**
   ** CSS
   **/

  // Disable CSS hover documentation
  "css.hover.documentation": false,

  /**
   ** TERMINAL
   **/
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.suggest.quickSuggestions": {
    "commands": "on",
    "arguments": "on",
    "unknown": "off"
  },

  /**
   ** PERFORMANCE
   **/
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true
  },
  "telemetry.telemetryLevel": "off",

  /**
   ** EXTENSIONS
   **/

  /** Markdown **/

  // Update TOC on save
  "markdown.extension.toc.updateOnSave": true,

  // TOC levels
  "markdown.extension.toc.levels": "2..6",

  /**
   ** SpecStory
   **/
  "specstory.cloudSync.enabled": "never",
  "specstory.autoSave.enabled": true,

  /**
   ** SPELLING
   **/
  // cSpell
  "cSpell.language": "en,fr",
  "cSpell.userWords": ["ai-driven-dev", "autofetch", "slugified", "aidd"],
  "cSpell.words": ["aidd"],

  /**
   ** LANGUAGES
   **/

  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },

  /** Typescript **/

  // Update imports on file move
  "typescript.updateImportsOnFileMove.enabled": "always",

  /** Javascript **/
  "javascript.updateImportsOnFileMove.enabled": "always",

  /** PHP **/
  "intelephense.files.maxSize": 1000000,
  "intelephense.files.associations": ["*.php"],
  "intelephense.environment.includePaths": ["./extension_aidd/playground/"],

  "path-intellisense.extensionOnImport": true,
  "path-intellisense.autoSlashAfterDirectory": true
}
